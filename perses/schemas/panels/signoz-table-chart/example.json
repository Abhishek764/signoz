{
    "kind": "SigNozTableChart",
    "spec": {
        "visualization": {
            "timePreference": "GLOBAL_TIME"
        },
        "formatting": {
            "columnUnits": {
                "A": "s"
            },
            "decimalPrecision": 2
        },
        "contextLinks": {
            "linksData": [
                {
                    "label": "View trace",
                    "url": "http://localhost:8080/trace/{{traceID}}"
                }
            ]
        },
        "thresholds": [
            {
                "value": 1,
                "operator": ">",
                "unit": "min",
                "color": "Red",
                "format": "Text",
                "tableOptions": "A"
            }
        ]
    }
}
