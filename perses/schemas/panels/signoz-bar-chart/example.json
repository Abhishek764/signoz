{
    "kind": "SigNozBarChart",
    "spec": {
        "visualization": {
            "timePreference": "GLOBAL_TIME",
            "fillSpans": false,
            "stackedBarChart": false
        },
        "formatting": {
            "yAxisUnit": "By",
            "decimalPrecision": 2
        },
        "axes": {
            "softMin": 0,
            "softMax": 1000,
            "isLogScale": false
        },
        "legend": {
            "position": "bottom",
            "customColors": {
                "series-A": "#9ea5f7"
            }
        },
        "contextLinks": {
            "linksData": [
                {
                    "label": "View details",
                    "url": "http://localhost:8080/{{_service.name}}"
                }
            ]
        },
        "thresholds": [
            {
                "thresholdValue": 500,
                "thresholdUnit": "By",
                "thresholdColor": "Red",
                "thresholdFormat": "Text",
                "thresholdLabel": "upper limit"
            }
        ]
    }
}
